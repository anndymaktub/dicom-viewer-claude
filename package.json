{
  "name": "dicom-viewer",
  "version": "1.0.0",
  "description": "DICOM Viewer built with Electron",
  "author": "Anndy",
  "license": "GPL-2.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-packager . \"DICOM Viewer\" --platform=win32 --arch=x64 --out=dist --overwrite --icon=build/icon.ico",
    "dist:portable": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win portable"
  },
  "build": {
    "appId": "com.anndy.dicom-viewer",
    "productName": "DICOM Viewer",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "files": [
      "main.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": []
  },
  "dependencies": {
    "@cornerstonejs/codec-openjpeg": "^1.0.0",
    "dicom-parser": "^1.8.21",
    "jpeg-js": "^0.4.4",
    "jpeg-lossless-decoder-js": "^2.0.5"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "png-to-ico": "^3.0.1"
  }
}
